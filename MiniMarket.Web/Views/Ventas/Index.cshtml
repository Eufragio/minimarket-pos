@model IEnumerable<MiniMarket.Web.Models.Venta>

@{
    ViewData["Title"] = "Historial de Ventas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-primary"><i class="fas fa-shopping-cart me-2"></i>Historial de Ventas</h2>
        <p class="text-muted">Consulta las ventas realizadas en el sistema.</p>
    </div>
    <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
        <i class="fas fa-cash-register me-2"></i> NUEVA VENTA
    </a>
</div>

<div class="card shadow border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="tablaVentas">
                <thead class="bg-light">
                    <tr>
                        <th>ID</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Vendedor</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Id.ToString("D5")</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Cliente != null)
                                {
                                    <span class="badge bg-info text-dark">@item.Cliente.Nombre</span>
                                }
                                else
                                {
                                    <span class="text-muted">Público General</span>
                                }
                            </td>
                            <td>
                                <small class="text-muted">@(item.Usuario != null ? item.Usuario.UserName : "Sistema")</small>
                            </td>
                            <td class="text-end fw-bold text-success">
                                S/. @item.Total.ToString("N2")
                            </td>
                            <td class="text-center">
                                <a asp-action="Ticket" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Ver Ticket" target="_blank">
                                    <i class="fas fa-print"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // --- CORRECCIÓN: EVITAR ERROR DE REINICIALIZACIÓN ---
            if ($.fn.DataTable.isDataTable('#tablaVentas')) {
                $('#tablaVentas').DataTable().destroy();
            }

            $('#tablaVentas').DataTable({
                "order": [[ 0, "desc" ]], // Ordenar por ID descendente (lo más reciente primero)
                language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json' }
            });
        });
    </script>
}